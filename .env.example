# Local/demo defaults. DEMO ONLY; replace every credential for production.
NODE_ENV=development
PORT=5000
APP_HOST_PORT=5001

# MySQL 8.4 local/demo (all application timestamps are UTC)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=edurag
DB_USER=root
DB_PASSWORD=123456
MYSQL_ROOT_PASSWORD=123456
MYSQL_HOST_PORT=3306
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
PYTHON_HOST_PORT=8000

# Access JWT
JWT_SECRET=demo-only-jwt-secret-change-before-production-2026
JWT_EXPIRES_IN=7d

# Password hashing for registration/change/reset. The SQL Demo Admin is pre-hashed.
BCRYPT_ROUNDS=12

# One-time token/OTP HMAC pepper
TOKEN_HMAC_PEPPER=demo-only-token-hmac-pepper-change-production

# Demo OTP delivery writes one-time secrets to app logs. Disable in production.
AUTH_DEV_DELIVERY_LOG_SECRETS=true

# Document upload
UPLOAD_DIR=uploads
FILE_MAX_SIZE_BYTES=20971520

# RAG adapter: mock runs without Python; remote calls the internal Python service
RAG_MODE=mock
RAG_SERVICE_URL=http://localhost:8000
# Must equal Python INTERNAL_SECRET and contain at least 32 characters.
RAG_INTERNAL_TOKEN=demo-only-rag-internal-token-change-production
RAG_REQUEST_TIMEOUT_MS=10000
RAG_QUERY_TIMEOUT_MS=60000
# Internal route only; sized for a complete full-text chunk manifest.
RAG_CALLBACK_BODY_LIMIT=25mb
RAG_HISTORY_MESSAGE_LIMIT=20
# Compatibility shim only; no subject scope is added to the NodeJS database/public API.
RAG_DEFAULT_SUBJECT_ID=mvp-global
# Absolute path as seen by Python. Node and Python must mount the same upload root here.
RAG_SHARED_UPLOAD_DIR=/shared/uploads
RAG_CALLBACK_URL=http://localhost:5000/api/internal/rag/processing-callback

# Optional deterministic mock controls for development/tests only
RAG_MOCK_MULTI_USAGE=false
# RAG_MOCK_SOURCE_VECTOR_NODE_ID=<existing document_chunks.vector_node_id>

# Remote Python providers. Keep real values only in ignored .env/process environment.
# Local Python credential file loaded by remote scripts/Compose. Do not commit it.
PYTHON_ENV_FILE=PythonSevice.env
GOOGLE_API_KEY=
LLAMA_CLOUD_API_KEY=
# Resolved Python model configuration. The embedding model is fixed for schema v1.0.0.
GEMINI_LLM_MODEL=models/gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768
QDRANT_COLLECTION_NAME=education_docs
RAG_CALLBACK_TIMEOUT_SECONDS=30
RAG_CALLBACK_MAX_RETRIES=3

# Isolated remote verification project. Choose unused host ports when needed.
REMOTE_COMPOSE_PROJECT=edurag_remote_e2e
REMOTE_E2E_CONFIRM_ISOLATED=false
REMOTE_E2E_INGEST_TIMEOUT_MS=300000
REMOTE_E2E_OPERATION_TIMEOUT_MS=120000
REMOTE_E2E_REQUIRE_LLAMAPARSE=true
REMOTE_E2E_TEST_UNAVAILABLE=true
