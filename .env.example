# Server
NODE_ENV=development
PORT=5000

# MySQL 8.4 (all application timestamps are UTC)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=edurag
DB_USER=edurag_user
DB_PASSWORD=replace_with_a_strong_database_password
MYSQL_ROOT_PASSWORD=replace_with_a_distinct_strong_root_password

# Access JWT
JWT_SECRET=replace_with_at_least_32_random_bytes
JWT_EXPIRES_IN=7d

# Idempotent Admin seed
ADMIN_EMAIL=admin@example.edu.vn
ADMIN_PASSWORD=replace_with_at_least_12_characters
ADMIN_FULL_NAME=EduRAG Administrator
BCRYPT_ROUNDS=12

# One-time token/OTP HMAC pepper
TOKEN_HMAC_PEPPER=replace_with_a_distinct_random_secret

# Development-only secret delivery adapter. Never enable in production.
AUTH_DEV_DELIVERY_LOG_SECRETS=false

# Reserved for the next Document/RAG vertical slice
UPLOAD_DIR=uploads
FILE_MAX_SIZE_BYTES=20971520
RAG_SERVICE_URL=http://localhost:8000
RAG_INTERNAL_TOKEN=replace_with_a_distinct_internal_service_token
RAG_REQUEST_TIMEOUT_MS=10000
