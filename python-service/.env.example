# Standalone Python development only. The integrated stack reads root ../.env.
GOOGLE_API_KEY=
LLAMA_CLOUD_API_KEY=
INTERNAL_SECRET=

GEMINI_LLM_MODEL=models/gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=education_docs

CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
SIMILARITY_THRESHOLD=0.35

CALLBACK_TIMEOUT=30
CALLBACK_MAX_RETRIES=3
